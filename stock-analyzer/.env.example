# ============================================
# KONFIGURASI SISTEM ANALISA SAHAM US
# ============================================
# CARA PENGGUNAAN:
# 1. Copy file ini menjadi .env
# 2. Isi semua nilai di bawah ini
# 3. JANGAN share file .env ke siapapun!
# ============================================

# --- TELEGRAM CONFIGURATION ---
# Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Dapatkan dari https://api.telegram.org/botTOKEN/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# --- ANALISA CONFIGURATION ---
# Daftar saham yang akan dianalisa (pisahkan dengan koma)
DEFAULT_WATCHLIST=AAPL,MSFT,GOOGL,NVDA,TSLA,META,AMZN,JPM,SPY,QQQ

# Modal investasi Anda (dalam USD) - untuk kalkulasi position sizing
PORTFOLIO_SIZE=10000

# Risiko maksimal per trade (dalam persen, contoh: 2 = 2%)
MAX_RISK_PER_TRADE=2

# --- JADWAL ANALISA OTOMATIS ---
# Format: HH:MM (waktu ET/Eastern Time = WIB - 11 jam)
# Contoh: 09:30 ET = 20:30 WIB
SCHEDULE_MORNING=09:30
SCHEDULE_MIDDAY=12:00
SCHEDULE_CLOSING=16:00

# --- ALERT THRESHOLDS ---
# RSI oversold (sinyal beli)
RSI_OVERSOLD=30
# RSI overbought (sinyal jual)
RSI_OVERBOUGHT=70

# Minimum score untuk kirim alert (0-100)
MIN_ALERT_SCORE=60

# --- TRADINGVIEW CONFIGURATION ---
# Username TradingView Anda (opsional, untuk fitur lanjutan)
TRADINGVIEW_USERNAME=
TRADINGVIEW_PASSWORD=
